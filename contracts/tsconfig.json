{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist"
  },
  "include": ["scripts/**/*.ts", "test/**/*.ts", "hardhat.config.ts"],
  "exclude": ["node_modules", "dist", "artifacts-hardhat", "cache"]
}
